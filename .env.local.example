# PostgreSQL connection string
# When using Docker Compose (docker compose up db):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/prompting_school

# Session encryption secret — must be at least 32 characters, keep private
SESSION_SECRET=replace-this-with-a-random-32-char-secret!!

# Anthropic API key — required for the prompt execution pipeline
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — required for billing (use test keys during development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — create these in the Stripe dashboard
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...

# App base URL — used for Stripe redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
